{"entities": [{"id": "ent_608836cfc6e9", "name": "AEM电解槽", "type": "PRODUCT", "industry": "科技-主题研究", "core": true, "desc": "AEM电解槽是Enapter公司的核心技术创新产品，属于阴离子交换膜（Anion Exchange Membrane）电解水制氢技术范畴。该技术在行业定位上旨在", "color": "#FFB347", "typeLabel": "产品", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_86c57f30b19e", "name": "AEM电解槽技术", "type": "TECH", "industry": "科技-主题研究", "core": true, "desc": "AEM电解槽技术是一种新兴的绿色制氢解决方案，旨在通过融合碱性电解与质子交换膜（PEM）电解的优势，解决传统制氢技术在成本与性能之间的平衡难题。该技术的主要竞争", "color": "#FF6B6B", "typeLabel": "技术", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_96f8969d3448", "name": "Enapter", "type": "ORG", "industry": "科技-主题研究", "core": true, "desc": "德国AEM电解槽公司，主打阴离子交换膜技术，将碱性电解槽低成本优势与PEM灵活紧凑优势结合。2022年营收1470万欧元同比增长75%，预计23年收入翻倍达30", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_2a1bb76b1421", "name": "HydrogenPro", "type": "ORG", "industry": "科技-主题研究", "core": true, "desc": "挪威碱性高压电解槽公司，主打30bar高压装置节省压缩成本，通过收购丹麦公司ApS加码电镀新技术将效率提高14%。2022年营收5650万挪威克朗同比增长183", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_dfda7aa55986", "name": "ITM Power", "type": "ORG", "industry": "科技-主题研究", "core": true, "desc": "英国PEM电解槽龙头，成立于2001年，全球PEM电解槽最大制造商之一，提供模块化解决方案。2022年营收560万英镑同比增长30%，在手订单755MW同比增长", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_58e98daeff24", "name": "McPhy", "type": "ORG", "industry": "科技-主题研究", "core": true, "desc": "法国碱性电解槽及加氢站公司，主打高压碱性电解槽包括Piel、McLyzer、Augmented McLyzer三款产品。2022年收入1600万欧元同比增长22", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_fe0db1e9944a", "name": "Nel ASA", "type": "ORG", "industry": "科技-主题研究", "core": true, "desc": "全球电解槽龙头全球电解槽龙头，ASA成立于1927年已有超90年碱性电解槽技术积累，2022年营业收入9.94亿挪威克朗电解槽业务占比75%，碱性电解槽营业收入", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_90bfc2c05f02", "name": "SOEC电解槽技术", "type": "TECH", "industry": "科技-主题研究", "core": true, "desc": "固体氧化物电解槽（SOEC）技术是绿氢制备领域的关键前沿工艺，主要定位于高温电化学制氢赛道，旨在通过高效能量转换推动清洁能源转型。该技术在850°C高温环境下运", "color": "#FF6B6B", "typeLabel": "技术", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_61bd59435539", "name": "七一八研究所", "type": "ORG", "industry": "科技-主题研究", "core": true, "desc": "七一八研究所自2000年起专注碱性、PEM及SOEC制氢电解槽技术研发与制造。该机构掌握电解槽核心部件设计、系统集成及工程化落地技术，其1000立方大型设备已通", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_e9e919cb8bed", "name": "中国双碳目标", "type": "POLICY", "industry": "科技-主题研究", "core": true, "desc": "中国承诺2030年碳排放强度降低65%，2060年实现碳中和。全球主要经济体均设定碳中和目标：英国2030年减排68%、欧盟2030年减排55%、美国2030年", "color": "#FF8C42", "typeLabel": "政策", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_2d71702881c1", "name": "中国石化", "type": "ORG", "industry": "科技-主题研究", "core": true, "desc": "中国石化主导国内油气上游勘探、炼油、化工、销售及新能源全链条运营。作为国家能源安全支柱，其原油加工量、成品油产量及化工产品供应均居国内首位。依托庞大基础设施网络", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_56fb2e32d5c8", "name": "中石化", "type": "ORG", "industry": "科技-主题研究", "core": true, "desc": "中国石油化工集团有限公司掌控国内最大综合性能源化工版图，贯通上游油气勘探开采、中游炼化加工至下游成品油销售的全产业链。作为国家能源安全支柱，其稳固国内油气供应并", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_66014ec71bfb", "name": "兰石重装", "type": "ORG", "industry": "科技-主题研究", "core": true, "desc": "兰石重装立足国内石化装备制造业，专注高端压力容器及成套装备制造。顺应能源转型，公司构建氢能制、储、运、加一体化布局，核心产品包括碱性电解槽、氢储球罐及高压储氢装", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_6b5b6678e0c9", "name": "内蒙古", "type": "PLACE", "industry": "科技-主题研究", "core": true, "desc": "内蒙古作为中国重要的能源基地，在绿氢产业布局中处于全国领先地位，依托其丰富的风能和太阳能资源，构建了极具竞争力的可再生能源制氢基础。该地区充分利用风光大基地优势", "color": "#95A5A6", "typeLabel": "地点", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_bd214bdddd95", "name": "挪威Nel ASA", "type": "ORG", "industry": "科技-主题研究", "core": true, "desc": "全球电解槽龙头，市值24亿美元，2021年收入0.7亿美元。兼具PEM及碱性电解槽技术，2022年碱性电解槽收入大增5倍，新增订单超2亿美元（同比增长135%）", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_87b88102461c", "name": "欧盟氢能战略", "type": "POLICY", "industry": "科技-主题研究", "core": true, "desc": "欧盟氢能战略是欧盟为实现2050年碳中和目标而制定的核心能源转型政策，旨在通过系统性部署绿氢产业链，确立欧洲在全球清洁能源领域的领导地位。该战略以2030年前实", "color": "#FF8C42", "typeLabel": "政策", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_6ca6b304327d", "name": "欧盟氢能政策", "type": "POLICY", "industry": "科技-主题研究", "core": true, "desc": "欧盟明确2030年安装至少40GW电解槽，绿氢年产能超1,000万吨，市场规模达1,400亿欧元。REPowerEU计划2030年可再生能源目标提至45%，8亿", "color": "#FF8C42", "typeLabel": "政策", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_6d7499e7ae0a", "name": "氢能电解槽行业", "type": "INDUSTRY", "industry": "科技-主题研究", "core": true, "desc": "氢能电解槽行业是绿氢制备的核心装备领域，专注于通过电化学方法将水分解为氢气和氧气，是实现能源结构低碳转型的关键基础设施。该行业以质子交换膜（PEM）和碱性电解技", "color": "#FFD700", "typeLabel": "行业", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_be4f75a0b43c", "name": "水电解制氢", "type": "TECH", "industry": "科技-主题研究", "core": true, "desc": "水电解制氢利用电能将水分解为氢气和氧气，是能源转型中实现深度脱碳的关键绿色技术。其产出氢气纯度极高，远超煤制氢与天然气制氢，精准契合电子工业、半导体制造等对品质", "color": "#FF6B6B", "typeLabel": "技术", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_5b39921d8a5b", "name": "水电解制氢设备", "type": "INDUSTRY", "industry": "科技-主题研究", "core": true, "desc": "水电解制氢是绿氢核心生产工艺，分为碱性电解（AWE）、质子交换膜电解（PEM）、阴离子膜电解（AEM）和固态氧化物电解（SOEC）四种技术路线。碱性电解为主流技", "color": "#FFD700", "typeLabel": "行业", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_58d2d9237739", "name": "电解槽", "type": "PRODUCT", "industry": "科技-主题研究", "core": true, "desc": "电解槽是水电解制氢系统中的核心装备，直接决定了绿氢生产的效率与经济性，在氢能产业链中占据关键地位。作为制氢环节的主要成本来源，其造价通常占整体系统成本的50%至", "color": "#FFB347", "typeLabel": "产品", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_d721c14bb1f8", "name": "电解槽行业", "type": "INDUSTRY", "industry": "科技-主题研究", "core": true, "desc": "水电解制氢核心设备，以碱性为主流适合规模化集中式生产，PEM在小型分布式领域作为补充。1000标方/h碱性电解槽整线含EPC价格1000万，设备900万，电解槽", "color": "#FFD700", "typeLabel": "行业", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_b17fb8b1013b", "name": "电解槽设备", "type": "INDUSTRY", "industry": "科技-主题研究", "core": true, "desc": "电解槽设备是氢能产业链中制氢环节的核心装备，主要应用于碱性及质子交换膜等主流制氢技术路线，直接决定绿氢生产的效率与成本。该行业具备高技术壁垒特征，在膜电极、双极", "color": "#FFD700", "typeLabel": "行业", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_e478d1d41010", "name": "碱性电解（ALK）", "type": "TECH", "industry": "科技-主题研究", "core": true, "desc": "碱性电解（ALK）技术是目前全球范围内最为成熟且商业化应用最广泛的电解水制氢方案，在绿氢产业链中占据基础性地位。该工艺采用氢氧化钾或氢氧化钠作为电解质，通过隔膜", "color": "#FF6B6B", "typeLabel": "技术", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_55f2f0751762", "name": "碱性电解槽行业", "type": "INDUSTRY", "industry": "科技-主题研究", "core": true, "desc": "碱性电解水制氢行业，2021年主要由718所、竞立和天津大陆三家占据绝大部分份额，21年双碳目标后隆基阳光等光伏企业进入，22年大批厂商涌入，行业可做及计划做碱", "color": "#FFD700", "typeLabel": "行业", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_a448890c2d6b", "name": "碱性高压电解槽", "type": "TECH", "industry": "科技-主题研究", "core": true, "desc": "碱性高压电解槽是HydroPro公司的核心制氢技术，专为高效、低成本的大规模绿氢生产而设计。该技术采用创新的30bar高压直出架构，显著降低了传统制氢流程中所需", "color": "#FF6B6B", "typeLabel": "技术", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_d3766213aa68", "name": "绿氢", "type": "PRODUCT", "industry": "科技-主题研究", "core": true, "desc": "绿氢利用风能、太阳能等可再生能源电力，通过电解水技术制备氢气，全生命周期碳排放接近零。其热值高达143MJ/kg，是替代化石能源、构建零碳体系的关键载体，也是实", "color": "#FFB347", "typeLabel": "产品", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_2b689b849fe6", "name": "绿氢产业", "type": "INDUSTRY", "industry": "科技-主题研究", "core": true, "desc": "绿氢是通过可再生能源发电电解水制氢，生产过程零碳排放。2021年全球纯氢气产量约7,000万吨，绿氢占比不足0.1%。预计2025年绿氢占比达2%，2030年占", "color": "#FFD700", "typeLabel": "行业", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_5d7627b299d1", "name": "绿氢行业", "type": "INDUSTRY", "industry": "科技-主题研究", "core": true, "desc": "通过光伏、风电及太阳能等可再生能源发电实现电解水制氢，生产过程零碳排放，具备大规模、长周期、长距离储能优势。21年全球纯氢气产量7000万吨，绿氢占比不足0.1", "color": "#FFD700", "typeLabel": "行业", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_74ce37783528", "name": "美国IRA氢能补贴", "type": "POLICY", "industry": "科技-主题研究", "core": true, "desc": "美国IRA氢能补贴是《通胀削减法案》中针对绿色氢能产业的核心激励政策，旨在通过45V税收抵免机制加速低碳氢能的商业化部署。该政策根据生产过程中的碳排放强度提供阶", "color": "#FF8C42", "typeLabel": "政策", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_e563d2e3b94b", "name": "考克利尔竞立", "type": "ORG", "industry": "科技-主题研究", "core": true, "desc": "国内大型碱性水电解制氢设备业绩最好的企业，已被考克利尔完全控股，计划2025年前发布3000立方单槽设备发展方向逐步由国内往国外拓展，已通过中国氢能联盟1000", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_722e82b6a952", "name": "英国ITM Power", "type": "ORG", "industry": "科技-主题研究", "core": true, "desc": "英国ITM Power专攻质子交换膜电解水制氢技术，与壳牌、林德等能源巨头建立战略合作以推进氢能基础设施建设。公司具备成熟的商业化技术储备及规模化生产能力，20", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_73883f348acb", "name": "PPS隔膜", "type": "TECH", "industry": "科技-主题研究", "core": false, "desc": "碱性电解槽核心隔膜材料，从石棉布已切换为PPS聚苯硫醚工程塑料，具备耐水解性耐高温120度耐腐蚀强度高，目前多采用东丽进口隔膜国产技术已突破但性能仍有差距，占电", "color": "#FF6B6B", "typeLabel": "技术", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_df8584e98464", "name": "中国地方氢能政策", "type": "POLICY", "industry": "科技-主题研究", "core": false, "desc": "中国多省份密集发布氢能政策：内蒙古目标2025年氢能产业总产值力争达到1,000亿元；青海目标2025年绿氢生产能力达4万吨；山西发布《氢能产业发展中长期规划（", "color": "#FF8C42", "typeLabel": "政策", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_fa4c84f6d808", "name": "亿利洁能", "type": "ORG", "industry": "科技-主题研究", "core": false, "desc": "亿利洁能股份有限公司，总市值174亿元，无投资评级。2022年收入3.8亿元（同比增长52%），氢能业务2022年订单1.2亿元，23年预计增长50%。光伏业务", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_4c1cd8d14f7f", "name": "内蒙古自治区《关于促进氢能产业高质量发展的意见》", "type": "POLICY", "industry": "科技-主题研究", "core": false, "desc": "该政策是内蒙古自治区为加速氢能产业布局、推动能源结构绿色转型而制定的关键指导性文件，旨在确立氢能作为未来清洁能源体系重要组成部分的战略地位。其核心特点在于构建了", "color": "#FF8C42", "typeLabel": "政策", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_323c2758105a", "name": "加氢站", "type": "INDUSTRY", "industry": "科技-主题研究", "core": false, "desc": "加氢站是氢能产业链中至关重要的基础设施节点，主要承担氢气储存、压缩及加注功能，为燃料电池汽车提供必要的能源补给服务。其主要竞争力在于通过高压储氢技术与高效加注流", "color": "#FFD700", "typeLabel": "行业", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_85894b21465d", "name": "华电重工", "type": "ORG", "industry": "科技-主题研究", "core": false, "desc": "华电重工股份有限公司依托中国华电集团背景，在电力装备领域占据重要地位。公司传统业务涵盖电站锅炉、压力容器等核心设备研发与制造，具备深厚技术积淀和全产业链服务能力", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_426d6979662d", "name": "可再生能源", "type": "ORG", "industry": "科技-主题研究", "core": false, "desc": "可再生能源作为全球能源转型的核心驱动力，涵盖太阳能、风能、水能及生物质能等清洁能源领域，旨在替代传统化石燃料以实现低碳可持续发展。该行业具备显著的政策驱动属性与", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_cdddf53d5342", "name": "合成氨行业", "type": "INDUSTRY", "industry": "科技-主题研究", "core": false, "desc": "合成氨行业是基础化工领域的核心支柱，主要作为氮肥生产的关键原料，同时广泛应用于化工、冶金及能源等多个下游产业。该行业具有显著的规模效应和资本密集特征，全球年产量", "color": "#FFD700", "typeLabel": "行业", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_cbe5c27ab64e", "name": "壳牌", "type": "ORG", "industry": "科技-主题研究", "core": false, "desc": "壳牌集团从事石油天然气勘探、开采、炼油、运输及销售，并加速向低碳能源转型。凭借全球顶尖的供应链网络，其在液化天然气领域确立市场主导与技术领先地位。作为《财富》世", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_cfc3177261ca", "name": "天津瀚氢源氢能机械公司", "type": "ORG", "industry": "科技-主题研究", "core": false, "desc": "碱性电解槽厂商已发货1100立方电解槽，HydrogenPro AS公司已从三菱电力公司获得1100立方单堆高压碱性电解槽系统采购订单，正在扩大和验证氢技术以实", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_835d6916955c", "name": "天然气掺氢", "type": "TECH", "industry": "科技-主题研究", "core": false, "desc": "天然气掺氢技术将氢气按比例注入现有天然气管网或燃烧设备，利用既有基础设施实现低碳能源输送。该方案无需大规模新建输配网络，即可显著降低化石能源碳足迹，同时保持高热", "color": "#FF6B6B", "typeLabel": "技术", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_263a2f93d57d", "name": "工业副产氢", "type": "ORG", "industry": "科技-主题研究", "core": false, "desc": "工业副产氢是氯碱、焦化及合成氨等重化工流程中伴生的二次能源资产，横跨能源与化工领域。凭借极低的边际生产成本和稳定供应能力，其在绿氢过渡期相比天然气重整制氢展现出", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_23c3694790cd", "name": "德国", "type": "PLACE", "industry": "科技-主题研究", "core": false, "desc": "德国是欧洲最大的经济体，也是全球第四大出口国，在金融知识图谱中作为核心区域实体，其定位为全球高端制造业与绿色金融转型的关键枢纽。该国拥有以汽车、机械和化工为主导", "color": "#95A5A6", "typeLabel": "地点", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_78a33d49ea24", "name": "德国Enapter", "type": "ORG", "industry": "科技-主题研究", "core": false, "desc": "德国Enapter利用专有阳极交换膜（AEM）电解技术，为工业、交通及能源存储提供高效紧凑的制氢设备。凭借小型化电解槽技术积累，公司大幅降低绿氢生产成本与空间需", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_58c1638bd7eb", "name": "德国Linde plc", "type": "ORG", "industry": "科技-主题研究", "core": false, "desc": "德国Linde plc生产并分销氧气、氮气、氩气等基础工业气体及特种气体，业务覆盖医疗、电子、能源和化工行业。凭借遍布全球的生产网络、先进分离技术专利及高效供应", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_f64b7e10c0e6", "name": "德国萨尔贝克基地", "type": "PLACE", "industry": "科技-主题研究", "core": false, "desc": "德国萨尔贝克基地是林德集团氢能产业链的关键制造枢纽，专攻大型碱性电解槽的研发与规模化生产。该基地于2021年9月动工，依托高度自动化生产线，目标实现每月生产1万", "color": "#95A5A6", "typeLabel": "地点", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_c8779c91b95b", "name": "挪威HydrogenPro", "type": "ORG", "industry": "科技-主题研究", "core": false, "desc": "挪威HydrogenPro专攻高压碱性电解槽的研发与制造，凭借在高压制氢领域的技术积淀，成为欧洲绿氢供应链的关键供应商。其设备以高效率和低运营成本著称，有效降低", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_04859e1ebe61", "name": "新疆", "type": "PLACE", "industry": "科技-主题研究", "core": false, "desc": "新疆作为我国重要的能源基地，在绿色能源转型中占据关键战略地位，正加速构建以绿氢为核心的新能源产业体系。依托得天独厚的风光资源禀赋，该地区具备大规模低成本可再生能", "color": "#95A5A6", "typeLabel": "地点", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_ef9a1650be06", "name": "昇辉科技", "type": "ORG", "industry": "科技-主题研究", "core": false, "desc": "昇辉科技依托智能配电及自动化控制技术积累，将业务从传统电气延伸至氢能产业链。公司构建了涵盖制氢设备、运营平台及配套电器的完整氢能业务闭环，已布局120辆氢能轻卡", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_cd90eef3d8f1", "name": "林德", "type": "ORG", "industry": "科技-主题研究", "core": false, "desc": "林德集团生产、储存并配送氧气、氮气、氩气等基础工业气体及特种气体。依托低温技术、气体分离工艺和高效供应链管理，公司构建起难以复制的竞争壁垒，提供高度定制化的气体", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_c6f4ae6819d3", "name": "法国政府补贴", "type": "POLICY", "industry": "科技-主题研究", "core": false, "desc": "法国政府补贴是法国国家氢能战略（Hydrogène pour la France）的核心财政支持工具，旨在通过巨额资金投入加速本土绿色氢能产业链的构建与成熟。该", "color": "#FF8C42", "typeLabel": "政策", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_c2c2481e01cc", "name": "煤气化制氢", "type": "TECH", "industry": "科技-主题研究", "core": false, "desc": "煤气化制氢通过高温高压将煤转化为合成气，经变换、净化提取氢气，主要应用于化工及能源领域。以9万标方/小时大型装置为例，投资约17亿元，吨氢耗煤3.8吨无烟煤；当", "color": "#FF6B6B", "typeLabel": "技术", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_c2a51ec183c1", "name": "碳排放", "type": "ORG", "industry": "科技-主题研究", "core": false, "desc": "但此处指代的是**专门从事碳排放监测、核算或交易服务的机构**（如碳交易所或第三方核查机构），以下是符合ORG类型的专业描述：\n\n该机构是专注于碳排放数据监测、", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_465cb1915f01", "name": "科威尔", "type": "ORG", "industry": "科技-主题研究", "core": false, "desc": "科威尔股份有限公司聚焦电力电子领域，提供高精度功率半导体测试设备及解决方案。公司依托深厚的技术积累，打通研发、生产至服务的全产业链环节。在电池包测试业务上表现突", "color": "#4A90D9", "typeLabel": "机构", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_f369702df28e", "name": "美国加州、德州", "type": "PLACE", "industry": "科技-主题研究", "core": false, "desc": "美国加州与德州作为全球能源转型的核心区域，在绿氢产业布局中占据战略主导地位，凭借丰富的可再生能源资源与成熟的工业基础，成为清洁氢能生产的关键枢纽。加州依托其领先", "color": "#95A5A6", "typeLabel": "地点", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_dafe278cbfee", "name": "质子交换膜电解（PEM）", "type": "TECH", "industry": "科技-主题研究", "core": false, "desc": "质子交换膜电解技术凭借毫秒级动态响应能力，精准适配风电、光伏等间歇性电源场景。该工艺支持高电流密度运行，电解效率突破90%，显著提升能源转化效能并产出高纯度氢气", "color": "#FF6B6B", "typeLabel": "技术", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_ed3f13c17dfd", "name": "隆基ALK Hi1制氢装备", "type": "PRODUCT", "industry": "科技-主题研究", "core": false, "desc": "隆基氢能2022年2月推出世界领先制氢装备系列产品，直流电耗满载状况低至4.3千瓦时每立方米Hi1 plus产品低至4.1千瓦时每立方米，可以降低10%以上直流", "color": "#FFB347", "typeLabel": "产品", "sector": "科技-主题研究", "subIndustry": ""}, {"id": "ent_a510fdc5fdfe", "name": "风光氢一体化", "type": "INDUSTRY", "industry": "科技-主题研究", "core": false, "desc": "风光氢一体化融合风能、太阳能发电与电解水制氢技术，通过多能互补平抑可再生能源间歇性波动，提升能源利用效率并降低制氢成本，推动氢能从“灰氢”向零碳排放的“绿氢”转", "color": "#FFD700", "typeLabel": "行业", "sector": "科技-主题研究", "subIndustry": ""}], "edges": [{"source": "ent_85894b21465d", "target": "ent_5b39921d8a5b", "type": "供应", "color": "#E74C3C"}, {"source": "ent_fa4c84f6d808", "target": "ent_5b39921d8a5b", "type": "供应", "color": "#E74C3C"}, {"source": "ent_ef9a1650be06", "target": "ent_5b39921d8a5b", "type": "供应", "color": "#E74C3C"}, {"source": "ent_465cb1915f01", "target": "ent_5b39921d8a5b", "type": "供应", "color": "#E74C3C"}, {"source": "ent_e9e919cb8bed", "target": "ent_2b689b849fe6", "type": "监管", "color": "#555555"}, {"source": "ent_6ca6b304327d", "target": "ent_2b689b849fe6", "type": "监管", "color": "#555555"}, {"source": "ent_df8584e98464", "target": "ent_2b689b849fe6", "type": "监管", "color": "#555555"}, {"source": "ent_6ca6b304327d", "target": "ent_bd214bdddd95", "type": "投资", "color": "#2ECC71"}, {"source": "ent_6b5b6678e0c9", "target": "ent_2b689b849fe6", "type": "投资", "color": "#2ECC71"}, {"source": "ent_bd214bdddd95", "target": "ent_722e82b6a952", "type": "合作", "color": "#2ECC71"}, {"source": "ent_58c1638bd7eb", "target": "ent_2b689b849fe6", "type": "合作", "color": "#2ECC71"}, {"source": "ent_d3766213aa68", "target": "ent_5b39921d8a5b", "type": "上下游", "color": "#3498DB"}, {"source": "ent_bd214bdddd95", "target": "ent_78a33d49ea24", "type": "竞争", "color": "#F39C12"}, {"source": "ent_6b5b6678e0c9", "target": "ent_2b689b849fe6", "type": "合作", "color": "#2ECC71"}, {"source": "ent_04859e1ebe61", "target": "ent_2b689b849fe6", "type": "合作", "color": "#2ECC71"}, {"source": "ent_fa4c84f6d808", "target": "ent_2b689b849fe6", "type": "客户", "color": "#1ABC9C"}, {"source": "ent_ef9a1650be06", "target": "ent_2b689b849fe6", "type": "客户", "color": "#1ABC9C"}, {"source": "ent_465cb1915f01", "target"